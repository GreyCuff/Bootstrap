<!DOCTYPE html>
<html>
<head>
  <title>My Dream Activities</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- STEP 1 - Bootstrap CSS link -->
  <link rel="stylesheet"
    href="https://maxcdn.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">

  <style>
    body {
      background-color: #eef8ff;
      font-family: Arial, sans-serif;
      padding: 30px 15px;
    }

    h1 {
      text-align: center;
      color: #1565C0;
      margin-bottom: 30px;
    }

    .hobby-card {
      text-align: center;
      border: 2px solid #1565C0;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 20px;
      background-color: #ffffff;
      box-shadow: 0px 4px 8px rgba(0,0,0,0.1);
    }

    .hobby-card h3 {
      color: #1565C0;
      margin-bottom: 10px;
    }

    .hobby-card p {
      color: #444;
    }
  </style>
</head>
<body>

  <h1>My Dream Activities</h1>

  <!-- STEP 2 - container keeps the layout neat and centred -->
  <div class="container">

    <!-- STEP 3 - row holds all the columns in one horizontal line -->
    <div class="row">

      <!-- STEP 4 - col-12: full width on phones
                   col-md-6: half width on tablets
                   col-lg-4: one-third on desktops -->
      <div class="col-12 col-md-6 col-lg-4">
        <div class="hobby-card">
          <h3>Photography</h3>
          <p>I enjoy capturing beautiful sunsets, nature, and memorable moments.</p>
        </div>
      </div>

      <div class="col-12 col-md-6 col-lg-4">
        <div class="hobby-card">
          <h3>Cooking</h3>
          <p>I love preparing tasty snacks and trying easy recipes with my family.</p>
        </div>
      </div>

      <div class="col-12 col-md-12 col-lg-4">
        <div class="hobby-card">
          <h3>Traveling</h3>
          <p>I dream of exploring new cities, meeting people, and learning about different cultures.</p>
        </div>
      </div>

    </div>
  </div>

  <!-- STEP 5 - Bootstrap JS script -->
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js">
  </script>

</body>
</html>
